rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Anexos de resposta das Companhias
    match /anexos/{atividadeId}/{opm}/{fileName} {
      allow read: if true;
      allow write: if resource == null && request.resource.size < 10 * 1024 * 1024;
    }

    // Documentos de referência do Batalhão
    match /refs/{atividadeId}/{fileName} {
      allow read: if true;
      allow write: if resource == null && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
